---
// src/pages/index.astro
// Demo: browser accent-color + prefers-color-scheme in Astro
---

<!doctype html>
<html lang="en" data-theme="light">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="color-scheme" content="light dark" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
        <title>Krafting Labs | Home</title>

        <style>
            /* @font-face { */
            /*     font-family: "JetBrainsMonoNerdFont"; */
            /*     src: url("/fonts/JetBrainsMonoNerdFontMono-Regular.woff2") format("woff2"); */
            /*     font-weight: 400; */
            /*     font-style: normal; */
            /* } */
            :root {
                /* Tell the browser the site supports both modes */
                color-scheme: light dark;
                --primary: #ff8c42;

                --bg-light: #faf8f5;
                --bg-dark: #171615;
                /* --border: #f2d7c0; */

                --nav-bg-light: #f2f0ec;
                --nav-bg-dark: #1e1d1b;

                --text-light: #2f261f;
                --text-dark: #d6d5d4;
                --logo-whisker: light-dark(#121212, #fafafa)
                /* --muted: #6b5c50; */
            }

            body {
                background: light-dark(var(--nav-bg-light), var(--nav-bg-dark));
                color: light-dark(var(--text-light), var(--text-dark));
            }

            * {
                margin: 0;
                font-family:
                    system-ui,
                    -apple-system,
                    BlinkMacSystemFont,
                    Roboto,
                    sans-serif;
            }

            .logo {
                display: flex;
                width: 100%;
                justify-content: center;
                height: 176px;
            }

            .brand {
                font-family: "JetBrainsMono Nerd Font", "Jet Brains Mono", "Fira Code", monospace;
                font-weight: 600;
            }

            .hero {
                /* min-height: 100vh; */
                min-height: 100vh;
                width: 100%;

                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;

                background: light-dark(var(--bg-light), var(--bg-dark));
                color: light-dark(var(--text-light), var(--text-dark));

                text-align: center;

                padding: 8rem 2rem 3rem;
                box-sizing: border-box;
            }

            .hero-text {
                margin-top: 1.5rem;
                max-width: 700px;

                font-size: 1.25rem;
                font-size: clamp(1.0rem, 1.4vw, 1.25rem);
                line-height: 1.4;
                opacity: 0.8;
            }

            .hero-button {
                display: inline-flex;
                align-items: center;
                justify-content: center;

                margin-top: 2rem;
                padding: 0.7rem 1.2rem;

                background: var(--primary);
                color: white;

                text-decoration: none;
                font-weight: 600;
            }

            .logo {
                padding-top: 4rem;
            }

            .logo svg {
                width: 176px;
                height: 176px;
            }

            nav {
                position: fixed;
                width: 100%;

                background: light-dark(var(--nav-bg-light), var(--nav-bg-dark));
            }

            .navbar {
                position: relative
                width: 100%;

                display: flex;
                padding: 1rem 1.5rem;
                justify-content: space-between;
                align-items: center;
            }

            .nav-curve-bottom {
                position: relative;
                width: 100%;
                height: 2rem;
                background: light-dark(var(--bg-light), var(--bg-dark));
                border-radius: 1rem 1rem 0 0;
            }

            .nav-link {
                text-decoration: none;
                color: var(--primary);
            }

            .ascii-logo {
                font-family: "jetbrains mono", monospace;
                white-space: pre;
                line-height: 1;
                font-size: clamp(7px, 1.0vw, 4rem);
                color: var(--primary);
            }

        </style>
    </head>

    <body>
        <nav>
            <div class="navbar">
                <div class="brand">Krafting Labs</div>

                <a
                    href="https://github.com/kraftinglabs"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="nav-link"
                >
                    GitHub
                </a>
            </div>
            <div class="nav-curve-bottom"></div>
        </nav>

